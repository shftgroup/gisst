    "typescript": "^5.8.2",
    "vite": "^8.0.16",
    "vite-plugin-checker": "^0.9.0",
    "sirv": "^3.0.2",
    "vite-mock-api": "github:joeosborn/vite-mock-api",
    "vite-plugin-mkcert": "^1.17.7"
  },
