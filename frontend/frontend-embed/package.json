{
  "name": "frontend-embed",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "module": "./dist/embed.js",
  "exports": {
    ".": {
      "import": "./dist/embed.js"
    },
    "./types": {
      "import": "./dist/types.d.ts"
    }
  },
  "types": "./dist/embed.d.ts",
  "scripts": {
    "dev": "shx mkdir -p ../../test-cert && node scripts/testdata.js && vite",
    "check": "tsc && eslint src",
    "build": "shx mkdir -p ../../test-cert && tsc && vite build",
    "dist": "shx mkdir -p ../../test-cert && vite build && shx mkdir -p ../../backend/embed-dist && shx cp -r dist/* ../../backend/embed-dist/",
    "preview": "vite preview",
    "test": "vitest --run",
    "testdata": "node scripts/testdata.js"
  },
  "devDependencies": {
    "@types/path-browserify": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@vitest/ui": "^4.1.8",
    "coffeescript": "^2.7.0",
    "eslint": "^9.13.0",
    "happy-dom": "^20.10.1",
    "rollup-plugin-sourcemaps": "0.6.3",
    "shx": "^0.4.0",
    "sirv": "^3.0.2",
    "typescript": "^5.8.2",
    "vite": "^8.0.16",
    "vite-plugin-checker": "^0.9.0",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-mkcert": "^1.17.6",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@zip.js/zip.js": "^2.7.53",
    "embedv86": "file:../embedv86",
    "path-browserify": "^1.0.1"
  }
}
